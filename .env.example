NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
JWT_SECRET=dev-secret-change-me

# Database: use DATABASE_URL for PostgreSQL or DB_FILE for SQLite
# SQLite (default for local dev):
DB_FILE=social.sqlite
# PostgreSQL (production):
# DATABASE_URL=postgres://user:password@host:5432/socialmvp

# SMTP is optional locally. If omitted, reset/verify endpoints return dev_token.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Social Media MVP <no-reply@example.com>"

# Next.js frontend. Empty means use same origin/proxy in dev.
NEXT_PUBLIC_API_URL=
